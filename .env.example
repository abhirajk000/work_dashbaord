# Postgres (server-only — set in Vercel project settings)
# Prod: VPS trackk DB. Local: tunnel to VPS or separate dev DB.
DATABASE_URL=postgresql://trackk_app:password@your-vps-ip:5432/trackk

# API auth (server-only — cron/scripts; browser uses PIN session cookie)
DASHBOARD_API_KEY=your-long-random-secret

# Optional separate secret for PIN session cookies (defaults to DASHBOARD_API_KEY)
# PIN_SESSION_SECRET=another-long-random-secret

# ntfy (optional — defaults to https://ntfy.sh topic Tracker)
# NTFY_SERVER=https://ntfy.sh
# APP_URL=https://track-raaz-0.vercel.app

# Protects /api/cron/reminders (Vercel sets Authorization: Bearer <CRON_SECRET> automatically)
CRON_SECRET=your-cron-secret

# Web Push (generate with: node scripts/generate-vapid-keys.mjs)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
