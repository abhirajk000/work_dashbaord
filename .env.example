# Neon Postgres (server-only — set in Vercel project settings)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# API auth (server-only)
DASHBOARD_API_KEY=your-long-random-secret

# Same value as DASHBOARD_API_KEY — exposed to the browser bundle
VITE_DASHBOARD_API_KEY=your-long-random-secret

# ntfy (optional — defaults to https://ntfy.sh topic Tracker)
# NTFY_SERVER=https://ntfy.sh
# APP_URL=https://work-raaz-0.vercel.app

# Protects /api/cron/reminders (Vercel sets Authorization: Bearer <CRON_SECRET> automatically)
CRON_SECRET=your-cron-secret
